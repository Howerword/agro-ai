{
  "name": "vitera-b2b-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w @agro/frontend",
    "dev:backend": "npm run start:dev -w @agro/backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run prisma:generate -w @agro/backend",
    "db:push": "npm run prisma:push -w @agro/backend",
    "db:migrate": "npm run prisma:migrate -w @agro/backend",
    "db:seed": "npm run prisma:seed -w @agro/backend",
    "import:vitera": "npm run import:vitera -w @agro/backend",
    "import:vitera:db": "npm run import:vitera:db -w @agro/backend"
  }
}
